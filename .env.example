# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Express Backend Port
PORT=5000

# Target Owner / Admin email address where all registration, enrollment, and contact form submissions are sent
OWNER_EMAIL="info@decodeias.com"
OWNER_CC_EMAIL="dcodesudhagaran@gmail.com"

# Optional SMTP Email Configuration (Nodemailer live transport)
# If these are left blank, emails will be logged safely in server logs and stored in the database.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_SECURE=false

# Optional: Direct Database Dashboard URL (e.g., Supabase project table editor link)
# If provided, the "Open Leads Database" button in the email will link directly to this page.
DATABASE_DASHBOARD_URL="https://supabase.com/dashboard/project/your-project-ref/editor"

# Supabase Database Settings
# Fill these in to store inquiries in your Supabase cloud project!
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-anon-public-key"
